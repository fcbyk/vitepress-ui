{
  "name": "@fcbyk/vitepress-ui",
  "version": "0.0.1-alpha.1",
  "description": "Custom themes and reusable components for VitePress.",
  "type": "module",
  "main": "components/index.ts",
  "module": "components/index.ts",
  "types": "components/index.ts",
  "exports": {
    ".": {
      "types": "./components/index.ts",
      "import": "./components/index.ts"
    }
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "components"
  ],
  "scripts": {
    "dev": "vitepress dev docs",
    "build:docs": "vitepress build docs",
    "preview:docs": "vitepress preview docs",
    "type-check": "vue-tsc --noEmit"
  },
  "keywords": [
    "VitePress", "themes", "components", "docs", "ui"
  ],
  "author": "fcbyk",
  "license": "MIT",
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitejs/plugin-vue": "^4.5.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.6.0",
    "vitepress": "^1.6.4",
    "vitest": "^1.0.0",
    "vue-tsc": "~1.8.27"
  }
}
